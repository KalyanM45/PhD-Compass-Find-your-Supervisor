# ── Required ──────────────────────────────────────────────────────────────────
# Groq API keys — used for Stage 1 (profile enrichment) and Stage 9 (why_match)
# Get keys at: https://console.groq.com/keys
#
# Multiple keys (comma-separated): the pool rotates to the next key instantly on
# a 429 rate-limit instead of sleeping.  Falls back to GROQ_API_KEY if not set.
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
# GROQ_API_KEY=gsk_singlekey   # single-key fallback

# ── Langfuse observability (optional) ────────────────────────────────────────
# Get keys at: https://cloud.langfuse.com — leave unset to disable tracing
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com   # or your self-hosted URL

# ── Optional (currently unused — reserved for future stages) ──────────────────
# Semantic Scholar API key (free tier works without a key; key raises rate limit)
# SEMANTIC_SCHOLAR_API_KEY=

# ORCID client credentials (public API works without auth for read access)
# ORCID_CLIENT_ID=
# ORCID_CLIENT_SECRET=
